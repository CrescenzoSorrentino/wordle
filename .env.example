# Copy this file to ".env" and fill in the real values.
# ".env" is git-ignored, so your secrets never end up in the repository.
#
# The NUXT_ prefix makes Nuxt override the matching runtimeConfig key
# (see nuxt.config.ts):
#   NUXT_UPSTASH_REDIS_REST_URL   -> runtimeConfig.upstashRedisRestUrl
#   NUXT_UPSTASH_REDIS_REST_TOKEN -> runtimeConfig.upstashRedisRestToken

# Upstash Redis credentials for the leaderboard (https://console.upstash.com).
# Found in your database dashboard under "REST API".
NUXT_UPSTASH_REDIS_REST_URL=
NUXT_UPSTASH_REDIS_REST_TOKEN=
